# =======================================================================
# Configuracao do servidor Cogni
# Copie este arquivo para .env e edite os valores reais.
# =======================================================================

# --- OpenAI (obrigatorio) ---
OPENAI_API_KEY=sk-sua-chave-aqui

# --- Servidor HTTP ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# --- Modelos ---
# STT padrao: gpt-4o-mini-transcribe (mais novo, ~22% mais preciso)
# Alternativa classica: whisper-1
# STT_MODEL=gpt-4o-mini-transcribe

# --- Modo desenvolvedor ---
# Coloque este segredo no fim do nome do usuario (ex: "Nicolas #trocar-em-producao")
# para liberar filtros de seguranca em conversas de teste.
DEVELOPER_SECRET=trocar-em-producao

# =======================================================================
# Supabase (fonte unica de dados — Companion + servidor)
# =======================================================================
# URL do projeto (Supabase -> Project Settings -> API -> Project URL).
# Formato: https://xxxxxxxx.supabase.co  (SEM o /rest/v1/ no fim)
SUPABASE_URL=https://seu-projeto.supabase.co
# Chave service_role (SECRETA — ignora RLS). SO no servidor, NUNCA no site.
# Supabase -> Project Settings -> API -> service_role (Reveal).
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui
# Sem essas duas variaveis o servidor roda 100% local (fallback usuarios.json).

# =======================================================================
# Integracao com o robo fisico (ESP32)
# =======================================================================

# Liga ou desliga o WebSocket /ws/esp (true por padrao).
ESP_ENABLED=true

# Token compartilhado entre servidor e ESP. DEVE ser o MESMO valor
# definido em code/esp32-*/config.h. Em desenvolvimento o servidor gera
# um token randomico se essa linha ficar vazia, mas isso quebra a
# conexao com o ESP a cada restart - melhor definir um valor fixo.
ESP_TOKEN=defina-um-token-secreto-aqui

# --- Cadencia / entonacao da voz (streaming por sentenca) ---
# A resposta sai por pedacos pra Cogni comecar a falar logo. Mas pedaco curto
# demais faz a voz perder entonacao/ritmo (o modelo de TTS nao tem contexto pra
# entoar). Estes dois controlam o tamanho minimo de cada pedaco:
#   _PRIMEIRA = a 1a frase (quanto MENOR, mais rapido o robo comeca, porem mais
#               "frio" se curto demais). Padrao 45 = bom equilibrio.
#   (geral)   = as frases seguintes. Padrao 90 = voz fluida e natural.
# Pra voltar ao "mais rapido porem frio" de antes: 22 / 60. Pra voz ainda mais
# natural (1a fala um tico mais tardia): suba os dois. Afine no ouvido.
# TTS_STREAM_MIN_CHARS_PRIMEIRA=45
# TTS_STREAM_MIN_CHARS=90

# --- Pipeline de voz do robo (microfone -> STT -> IA -> TTS -> robo) ---

# Liga o processamento automatico do audio que chega do INMP441.
# Quando true, qualquer chunk PCM binario que chegar em /ws/esp passa por
# VAD (deteccao de fala), e ao detectar fim de fala dispara o pipeline
# completo (Whisper -> GPT -> TTS) e devolve o audio PCM ao robo (24kHz,
# 16-bit mono - o ESP toca direto no I2S, sem decodificar MP3).
ESP_PIPELINE_HABILITADO=true

# Usuario padrao quando o robo nao envia um {tipo:"voz-config"} explicito.
# Crie o usuario uma vez via interface web e cole o ID aqui se quiser
# memoria persistente. Use "default" para sessao anonima.
ESP_USUARIO_PADRAO=default

# Taxa de amostragem que o INMP441 esta enviando (Hz). 16000 e o padrao
# do Whisper e do firmware esp32-controle.
ESP_MIC_SAMPLE_RATE=16000

# Limiar RMS para detectar inicio de fala (PCM 16 bits).
# Aumente se houver muito ruido ambiente disparando o pipeline a toa.
ESP_MIC_VAD_RMS_INICIO=800

# Limiar RMS para considerar que continua falando (deve ser menor que
# ESP_MIC_VAD_RMS_INICIO para nao cortar pausas naturais).
ESP_MIC_VAD_RMS_SILENCIO=500

# Tempo de silencio sustentado (ms) que define "fim de fala".
ESP_MIC_SILENCIO_MS_FIM=1200

# Duracao maxima de uma captura (ms). Forca o disparo do pipeline mesmo
# se a crianca nao parar de falar - evita estourar memoria.
ESP_MIC_MAX_DURACAO_MS=20000

# Duracao minima de uma captura (ms). Capturas mais curtas sao descartadas
# (provavelmente ruido).
ESP_MIC_MIN_DURACAO_MS=300

# Limite duro do buffer por sessao (bytes). 16000 amostras/s * 2 bytes * 20s.
ESP_MIC_MAX_BUFFER_BYTES=640000

# --- Volume da voz do robo ---
# Ganho aplicado ao audio da Cogni antes de enviar ao robo. 1.0 = volume nativo
# da OpenAI; 1.5 (padrao) = mais alto, com limitador suave que evita distorcao
# nos picos. Faixa segura ~1.0 a 2.0. Se ficar alto/abafado demais, baixe; se
# faltar volume, suba ate ~2.0 (acima disso a voz comeca a "achatar"). Se mesmo
# em 2.0 faltar volume, o ajuste e fisico: pino GAIN do MAX98357A.
ESP_AUDIO_GANHO=1.5

# --- Controle de fluxo do audio (malha fechada servidor <-> robo) ---
# O robo reporta quantos ms de audio ainda tem para tocar; o servidor regula o
# ritmo de envio para manter essa fila perto do ALVO. Isso elimina o picote/
# duplicacao/loop de audio (underrun do DMA) no meio e fim da fala. Os defaults
# do codigo ja sao bons - so mexa se for afinar.
# Nivel de buffer alvo no robo (ms de audio em maos). 420ms cobre o tempo de
# sintese da proxima frase no streaming, pra fala nao "travar" na juncao entre
# frases. Se notar pausas entre frases, suba; se o barge-in (interromper falando
# por cima) ficar lento, baixe.
ESP_AUDIO_BUFFER_ALVO_MS=420
# Teto: acima disso o servidor segura o envio (nao enche demais a fila do firmware).
ESP_AUDIO_BUFFER_TETO_MS=620
# Quantos chunks iniciais vao em rajada para encher o colchao no inicio da fala.
ESP_AUDIO_BURST_CHUNKS=4

# --- Anti-eco / barge-in (robo se ouvindo falar) ---
# Enquanto o robo fala, o VAD exige um limiar ESTE_FATOR vezes mais alto para
# aceitar voz: barra o eco fraco do alto-falante, mas deixa a crianca interromper.
ESP_MIC_ECO_FATOR_LIMIAR=4.0
# Folga (ms) apos a fala para o buffer I2S do ESP esvaziar antes de voltar a ouvir.
ESP_MIC_ECO_GUARDA_MS=500

# --- Heartbeat (confiabilidade da conexao com o robo) ---
# Intervalo do ping do servidor ao robo e quantos pings sem pong toleramos antes
# de derrubar. Valores folgados evitam a desconexao "do nada" do modem-sleep.
ESP_HEARTBEAT_MS=30000
ESP_HEARTBEAT_MAX_FALHAS=2
